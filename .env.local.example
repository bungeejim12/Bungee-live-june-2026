NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only (optional if using SUPABASE_DIRECT_URL for migrations/admin scripts)
# SUPABASE_SECRET_KEY="sb_secret_..."
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Direct Postgres connection — used for migrations (scripts/apply-migration.mjs)
SUPABASE_DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
SUPABASE_PASSWORD=

NEXT_PUBLIC_APP_URL=http://localhost:3000
